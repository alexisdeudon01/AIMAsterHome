{
  "name": "HA Analyst + Dashboard & Integration Recommender",
  "version": "2.0.0",
  "slug": "ai_dashboard_builder",
  "description": "Claude-powered HA analyst: proposes dashboards, integrations, and HACS add-ons with approval-gated execution.",
  "startup": "application",
  "boot": "auto",
  "init": false,
  "homeassistant_api": true,
  "hassio_api": true,
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:view-dashboard-variant",
  "panel_title": "HA Analyst",
  "arch": ["aarch64", "amd64", "armv7", "i386"],
  "map": ["config:rw"],
  "options": {
    "anthropic_api_key": "",
    "anthropic_model": "claude-3-5-sonnet-latest",
    "ha_url": "http://supervisor/core",
    "poll_interval_minutes": 0,
    "collect_logs": false,
    "log_lines": 100
  },
  "schema": {
    "anthropic_api_key": "str",
    "anthropic_model": "str",
    "ha_url": "str",
    "poll_interval_minutes": "int",
    "collect_logs": "bool",
    "log_lines": "int"
  }
}
